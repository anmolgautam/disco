# Set both keys; LLM_PROVIDER picks which one is active.
# If LLM_PROVIDER is unset, defaults to anthropic when its key is present.
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Basic Auth gate for /campaign. Set BOTH in production.
# If either is empty, the gate is disabled (local dev convenience).
AUTH_USERNAME=
AUTH_PASSWORD=
